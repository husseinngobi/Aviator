{
  "manifest_version": 3,
  "name": "WebSocket Telemetry Extension",
  "version": "1.3",
  "short_name": "Aviator WS",
  "description": "Automatic WebSocket telemetry monitor for realtime dashboard ingestion.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://fortebet.com/*",
    "*://*.fortebet.com/*",
    "*://fortebet.ug/*",
    "*://*.fortebet.ug/*",
    "*://mobile.fortebet.ug/*",
    "*://www.fortebet.com/*",
    "*://www.fortebet.ug/*",
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_title": "Telemetry Monitor Active"
  },
  "content_scripts": [
    {
      "matches": [
        "*://fortebet.com/*",
        "*://*.fortebet.com/*",
        "*://fortebet.ug/*",
        "*://*.fortebet.ug/*",
        "*://mobile.fortebet.ug/*",
        "*://www.fortebet.com/*",
        "*://www.fortebet.ug/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["monitor.js"],
      "matches": [
        "*://fortebet.com/*",
        "*://*.fortebet.com/*",
        "*://fortebet.ug/*",
        "*://*.fortebet.ug/*",
        "*://mobile.fortebet.ug/*",
        "*://www.fortebet.com/*",
        "*://www.fortebet.ug/*"
      ]
    }
  ]
}